# --- Find🐾 server config ---

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Firebase Admin SDK
# Download a service account JSON from Firebase Console → Project Settings → Service Accounts.
# Paste the client_email and private_key fields below (escape newlines as \n).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...REPLACE_ME...IDAQAB\n-----END PRIVATE KEY-----\n"

# Optional: AI microservice URL. If unset, server uses the pure-JS predictor.
AI_SERVICE_URL=http://localhost:8000

# Device auth — shared secret used to derive device API keys
DEVICE_KEY_SALT=change-me-to-a-long-random-string

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
